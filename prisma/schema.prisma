// Northgate Institute of Technology — Production Schema
// Prisma + SQLite (swap provider to postgresql for production deployment)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
//  AUTHENTICATION & AUTHORIZATION
// ─────────────────────────────────────────────────────────────────────

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  emailNormalized     String       @unique
  name                String
  passwordHash        String?
  image               String?
  phone               String?
  role                String       @default("STUDENT") // ADMIN | EDITOR | STUDENT
  status              String       @default("ACTIVE")  // ACTIVE | SUSPENDED | PENDING
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?
  twoFactorEnabled    Boolean      @default(false)
  twoFactorSecret     String?
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  applications        Application[]
  authoredNews        News[]
  authoredEvents      Event[]
  student             Student?
  authoredAnnouncements Announcement[]
  sentMessages        Message[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // LOGIN | LOGOUT | CREATE | UPDATE | DELETE | RESTORE | PUBLISH | etc.
  resource  String   // User | Department | Programme | News | etc.
  resourceId String?
  metadata  String?  // JSON string
  ip        String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
//  ACADEMIC CONTENT
// ─────────────────────────────────────────────────────────────────────

model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  tagline     String
  description String?
  icon        String?
  imageUrl    String?
  accentColor String?
  sortOrder   Int         @default(0)
  status      String      @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  programmes  Programme[]
  units       Unit[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([sortOrder])
  @@index([deletedAt])
}

model Programme {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  slug          String       @unique
  description   String
  departmentId  String
  department    Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  qualification String       // Certificate | Diploma | Higher Diploma | Degree | Short Course
  duration      String       // e.g. "3 years"
  durationMonths Int
  mode          String       @default("FULL_TIME") // FULL_TIME | PART_TIME | EVENING | ONLINE
  fee           Int          @default(0)
  currency      String       @default("KES")
  intake        String       @default("September")
  requirements  String?      // JSON string array
  careerPaths   String?      // JSON string array
  imageUrl      String?
  status        String       @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  featured      Boolean      @default(false)
  sortOrder     Int          @default(0)
  applications  Application[]
  students      Student[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([departmentId])
  @@index([qualification])
  @@index([status])
  @@index([featured])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────
//  MARKETING CONTENT
// ─────────────────────────────────────────────────────────────────────

model News {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String
  content      String
  category     String   @default("Latest News") // Latest News | Research | Innovation | Conferences
  imageUrl     String?
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  status       String   @default("DRAFT") // DRAFT | PUBLISHED | SCHEDULED | ARCHIVED
  publishedAt  DateTime?
  scheduledAt  DateTime?
  readTime     Int      @default(3)
  tags         String?  // JSON string array
  views        Int      @default(0)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([status, publishedAt])
  @@index([category])
  @@index([slug])
  @@index([deletedAt])
}

model Event {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  description  String
  category     String    @default("Upcoming Events") // Upcoming Events | Conferences
  location     String?
  imageUrl     String?
  startDate    DateTime
  endDate      DateTime?
  authorId     String?
  author       User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  status       String    @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  capacity     Int?
  registered   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([status, startDate])
  @@index([category])
  @@index([deletedAt])
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String
  type       String   @default("student") // student | employer | graduate
  quote      String
  avatarUrl  String?
  org        String?
  rating     Int      @default(5)
  status     String   @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([status])
  @@index([deletedAt])
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  short      String
  logoUrl    String?
  website    String?
  category   String   @default("ACCREDITATION") // ACCREDITATION | INDUSTRY | GOVERNMENT
  sortOrder  Int      @default(0)
  status     String   @default("PUBLISHED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([status])
  @@index([deletedAt])
}

model GalleryImage {
  id         String   @id @default(cuid())
  title      String
  alt        String
  imageUrl   String
  category   String   @default("Campus Life") // Workshop | Lab | Graduation | Campus Life | Sports
  width      Int?
  height     Int?
  sortOrder  Int      @default(0)
  status     String   @default("PUBLISHED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([status])
  @@index([category])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────
//  ADMISSIONS & ENGAGEMENT
// ─────────────────────────────────────────────────────────────────────

model Application {
  id            String    @id @default(cuid())
  reference     String    @unique
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName     String
  lastName      String
  email         String
  phone         String
  programmeId   String
  programme     Programme @relation(fields: [programmeId], references: [id], onDelete: Restrict)
  intake        String
  qualification String?
  status        String    @default("PENDING") // PENDING | REVIEWING | ACCEPTED | REJECTED | ENROLLED
  notes         String?
  metadata      String?   // JSON string
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([programmeId])
  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("NEW") // NEW | READ | REPLIED | ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("ACTIVE") // ACTIVE | UNSUBSCRIBED | BOUNCED
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ─────────────────────────────────────────────────────────────────────
//  STUDENT INFORMATION SYSTEM
// ─────────────────────────────────────────────────────────────────────

model Student {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  admissionNo     String       @unique
  programmeId     String?
  programme       Programme?   @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  year            Int          @default(1)
  semester        Int          @default(1)
  status          String       @default("ACTIVE") // ACTIVE | SUSPENDED | GRADUATED | ON_LEAVE
  enrollmentDate  DateTime     @default(now())
  gender          String?
  dateOfBirth     DateTime?
  nationality     String?
  idNumber        String?
  phone           String?
  address         String?
  nextOfKin       String?
  nextOfKinPhone  String?
  profileImageUrl String?
  profileComplete Int          @default(40)
  currentGPA      Float        @default(0)
  attendanceRate  Float        @default(0)
  overallProgress Int          @default(0)
  enrollments     Enrollment[]
  attendances     Attendance[]
  results         Result[]
  fees            Fee[]
  payments        Payment[]
  examCards       ExamCard[]
  bookLoans       BookLoan[]
  hostelAlloc     HostelAllocation?
  notifications   Notification[]
  sentMessages    Message[]    @relation("MessageFrom")
  receivedMessages Message[]   @relation("MessageTo")
  submissions     Submission[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([programmeId])
  @@index([status])
}

model Semester {
  id          String   @id @default(cuid())
  name        String   @unique // "Semester 1, 2025/2026"
  code        String   @unique // "2025/2026-S1"
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean  @default(false)
  academicYear String
  units       Unit[]
  enrollments Enrollment[]
  assessments Assessment[]
  results     Result[]
  fees        Fee[]
  examCards   ExamCard[]
  createdAt   DateTime @default(now())

  @@index([isCurrent])
  @@index([academicYear])
}

model Unit {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  description   String?
  credits       Int          @default(1)
  departmentId  String
  department    Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semesterId    String?
  semester      Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  instructor    String?
  year          Int          @default(1)
  enrollments   Enrollment[]
  assessments   Assessment[]
  attendances   Attendance[]
  results       Result[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([departmentId])
  @@index([semesterId])
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  status     String   @default("ENROLLED") // ENROLLED | COMPLETED | DROPPED
  enrolledAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([studentId, unitId, semesterId])
  @@index([studentId])
  @@index([unitId])
}

model Assessment {
  id          String       @id @default(cuid())
  unitId      String
  unit        Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  title       String
  type        String       @default("ASSIGNMENT") // ASSIGNMENT | CAT | EXAM | POE_REQUEST | POE_SUBMISSION | PROJECT
  description String?
  maxMarks    Int          @default(100)
  weight      Float        @default(1.0)
  dueDate     DateTime
  semesterId  String?
  semester    Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@index([unitId])
  @@index([dueDate])
  @@index([type])
}

model Submission {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedAt  DateTime?
  marks        Int?
  feedback     String?
  status       String     @default("PENDING") // PENDING | SUBMITTED | GRADED | LATE
  fileUrl      String?
  createdAt    DateTime   @default(now())

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([status])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String   @default("PRESENT") // PRESENT | ABSENT | LATE | EXCUSED
  createdAt DateTime @default(now())

  @@unique([studentId, unitId, date])
  @@index([studentId])
  @@index([unitId])
  @@index([date])
}

model Result {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  marks      Int
  grade      String    // A | B | C | D | E | F
  gpa        Float
  releasedAt DateTime?
  status     String    @default("DRAFT") // DRAFT | RELEASED
  createdAt  DateTime  @default(now())

  @@unique([studentId, unitId, semesterId])
  @@index([studentId])
  @@index([status])
}

model Fee {
  id         String     @id @default(cuid())
  studentId  String
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterId String?
  semester   Semester?  @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  type       String     // TUITION | LAB | LIBRARY | HOSTEL | EXAM | LATE | OTHER
  amount     Int
  dueDate    DateTime
  status     String     @default("PENDING") // PENDING | PARTIAL | PAID | OVERDUE
  payments   Payment[]
  createdAt  DateTime   @default(now())

  @@unique([studentId, semesterId, type])
  @@index([studentId])
  @@index([status])
}

model Payment {
  id         String   @id @default(cuid())
  feeId      String
  fee        Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Int
  method     String   @default("MPESA") // MPESA | CARD | BANK | CASH
  reference  String   @unique
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([feeId])
}

model ExamCard {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  status     String    @default("PENDING") // PENDING | APPROVED | ISSUED | REVOKED
  issuedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@index([studentId])
}

model LibraryBook {
  id              String    @id @default(cuid())
  title           String
  author          String
  isbn            String?
  category        String    @default("General")
  totalCopies     Int       @default(1)
  availableCopies Int       @default(1)
  coverUrl        String?
  description     String?
  loans           BookLoan[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
}

model BookLoan {
  id         String     @id @default(cuid())
  bookId     String
  book       LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  borrowedAt DateTime   @default(now())
  dueAt      DateTime
  returnedAt DateTime?
  status     String     @default("ACTIVE") // ACTIVE | RETURNED | OVERDUE
  createdAt  DateTime   @default(now())

  @@index([studentId])
  @@index([status])
}

model Hostel {
  id         String   @id @default(cuid())
  name       String   @unique
  block      String
  gender     String   @default("ANY") // MALE | FEMALE | ANY
  capacity   Int
  occupied   Int      @default(0)
  allocations HostelAllocation[]
  createdAt  DateTime @default(now())

  @@index([gender])
}

model HostelAllocation {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hostelId    String
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  roomNo      String
  allocatedAt DateTime @default(now())

  @@index([hostelId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  audience    String   @default("ALL") // ALL | STUDENTS | STAFF
  category    String   @default("General") // General | Academic | Finance | Events | Urgent
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([audience])
  @@index([publishedAt])
}

model Notification {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String    @default("INFO") // INFO | SUCCESS | WARNING | ERROR | ACADEMIC | FINANCE | ANNOUNCEMENT
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([studentId])
  @@index([readAt])
}

model Message {
  id         String   @id @default(cuid())
  fromStudentId String?
  fromStudent Student? @relation("MessageFrom", fields: [fromStudentId], references: [id], onDelete: Cascade)
  toStudentId String?
  toStudent   Student? @relation("MessageTo", fields: [toStudentId], references: [id], onDelete: Cascade)
  fromUserId  String?
  fromUser    User?    @relation(fields: [fromUserId], references: [id], onDelete: SetNull)
  subject     String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([fromStudentId])
  @@index([toStudentId])
}
