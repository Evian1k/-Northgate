# ───────────────────────────────────────────────────────────
#  Northgate — Demo Environment (zero-config deploy)
#  These are SAFE demo defaults. Override with real secrets in production.
# ───────────────────────────────────────────────────────────

# Database — SQLite at /tmp (writable on Vercel serverless)
# Data is ephemeral (resets on cold start) — perfect for demos
# For production: use PostgreSQL via DATABASE_URL=postgresql://...
DATABASE_URL=file:/tmp/northgate.db

# JWT secrets — demo values (replace with `openssl rand -hex 32` in production)
JWT_ACCESS_SECRET=demo-access-secret-not-for-production-use-32chars
JWT_REFRESH_SECRET=demo-refresh-secret-not-for-production-use-32chars

# Backend API URL — empty = use built-in Next.js API routes
# For Laravel backend: NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=

# Enable demo one-click login (set to "false" in production)
ENABLE_DEMO_LOGIN=true
